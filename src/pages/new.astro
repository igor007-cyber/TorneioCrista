---
// Página de configuração de um novo torneio.
// Ao submeter, gera o torneio e redireciona para a listagem em /.
import MainLayout from '../layouts/main.astro';
---

<MainLayout title="CopaCrista — Novo Torneio">
	<main class="max-w-4xl mx-auto px-5 py-10 md:py-14">
		<!-- Voltar -->
		<a href="/" class="inline-flex items-center gap-1 text-sm text-blue-700 hover:text-blue-900 font-medium mb-4">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
			Meus torneios
		</a>

		<!-- Cabeçalho -->
		<header class="text-center mb-10 cc-animate-in">
			<div class="inline-flex items-center gap-3 mb-4">
				<div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-600 grid place-items-center shadow-lg shadow-blue-500/30">
					<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
						<path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
						<path d="M4 22h16"/>
						<path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
						<path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
						<path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
					</svg>
				</div>
				<h1 class="text-3xl md:text-4xl font-extrabold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-700 bg-clip-text text-transparent">
					Novo Torneio
				</h1>
			</div>
			<p class="text-slate-600 text-lg">Configure uma nova competição</p>
			<p class="text-slate-500 text-sm mt-1">Defina esporte, formato e times — o sistema monta as tabelas para você.</p>
		</header>

		<!-- Formulário -->
		<form id="config-form" class="cc-card rounded-3xl p-6 md:p-10 space-y-8 cc-animate-in" novalidate>
			<!-- Esporte -->
			<section>
				<h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">Esporte</h2>
				<div class="cc-pill" role="radiogroup" aria-label="Esporte">
					<input type="radio" id="sport-futebol" name="sport" value="futebol" checked />
					<label for="sport-futebol">⚽ Futebol</label>
					<input type="radio" id="sport-basquete" name="sport" value="basquete" />
					<label for="sport-basquete">🏀 Basquete</label>
					<input type="radio" id="sport-volei" name="sport" value="volei" />
					<label for="sport-volei">🏐 Vôlei</label>
				</div>
			</section>

			<!-- Gênero -->
			<section>
				<h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">Categoria</h2>
				<div class="cc-pill" role="radiogroup" aria-label="Categoria">
					<input type="radio" id="gender-m" name="gender" value="masculino" checked />
					<label for="gender-m">Masculino</label>
					<input type="radio" id="gender-f" name="gender" value="feminino" />
					<label for="gender-f">Feminino</label>
				</div>
			</section>

			<!-- Formato -->
			<section>
				<h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">Formato da competição</h2>
				<div class="cc-pill" role="radiogroup" aria-label="Formato">
					<input type="radio" id="fmt-grupos" name="format" value="grupos" checked />
					<label for="fmt-grupos">Fase de Grupos</label>
					<input type="radio" id="fmt-corrido" name="format" value="corrido" />
					<label for="fmt-corrido">Campeonato Corrido</label>
					<input type="radio" id="fmt-ko" name="format" value="mata-mata" />
					<label for="fmt-ko">Mata-Mata</label>
				</div>
				<p id="format-hint" class="text-xs text-slate-500 mt-2"></p>
			</section>

			<!-- Times -->
			<section>
				<div class="flex items-center justify-between mb-3">
					<h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Times participantes</h2>
					<div class="flex items-center gap-2">
						<label for="team-count" class="text-xs text-slate-600 font-medium">Quantidade:</label>
						<div class="flex items-center rounded-xl bg-blue-50 border border-blue-200">
							<button type="button" id="btn-minus" class="px-3 py-1.5 text-blue-700 font-bold hover:bg-blue-100 rounded-l-xl">−</button>
							<input id="team-count" type="number" min="3" max="32" value="4"
								class="w-14 text-center bg-transparent border-0 font-semibold text-blue-800 focus:outline-none" />
							<button type="button" id="btn-plus" class="px-3 py-1.5 text-blue-700 font-bold hover:bg-blue-100 rounded-r-xl">+</button>
						</div>
					</div>
				</div>
				<div id="teams-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>
				<p id="teams-error" class="text-sm text-rose-600 mt-2 hidden"></p>
			</section>

			<!-- Ações -->
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-end gap-3 pt-2">
				<button type="button" id="btn-fill" class="cc-btn cc-btn-ghost">
					Preencher com exemplos
				</button>
				<button type="submit" class="cc-btn cc-btn-primary sm:ml-auto text-base">
					Gerar Tabela
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5 12h14M13 5l7 7-7 7"/>
					</svg>
				</button>
			</div>
		</form>
	</main>
</MainLayout>

<script>
	import { generateTournament } from '../lib/tournament';
	import { saveTournament } from '../lib/storage';
	import type { Config, Format, Gender, Sport } from '../lib/types';

	// Times-exemplo conforme o esporte — só para acelerar testes.
	const EXAMPLE_TEAMS: Record<Sport, string[]> = {
		futebol:  ['Real Crista', 'Vila Nova', 'Atlético FC', 'União SC', 'Esporte Clube', 'Boavista', 'Grêmio Norte', 'Santa Cruz'],
		basquete: ['Lakers BR', 'Eagles', 'Titans', 'Warriors SP', 'Raptors RJ', 'Hawks', 'Pacers', 'Nets RS'],
		volei:    ['Praia Azul', 'Costa Sol', 'Vulcão', 'Litoral', 'Orquídea', 'Maresia', 'Tornado', 'Estrela'],
	};

	const HINTS: Record<Format, string> = {
		grupos:      'Os times são distribuídos em grupos, os 2 primeiros de cada grupo avançam para o mata-mata.',
		corrido:     'Todos jogam contra todos; o campeão é quem somar mais pontos ao final.',
		'mata-mata': 'Eliminação direta — em caso de número ímpar, as melhores posições começam com BYE.',
	};

	const grid         = document.getElementById('teams-grid') as HTMLDivElement;
	const countInput   = document.getElementById('team-count') as HTMLInputElement;
	const btnPlus      = document.getElementById('btn-plus') as HTMLButtonElement;
	const btnMinus     = document.getElementById('btn-minus') as HTMLButtonElement;
	const btnFill      = document.getElementById('btn-fill') as HTMLButtonElement;
	const errEl        = document.getElementById('teams-error') as HTMLParagraphElement;
	const hintEl       = document.getElementById('format-hint') as HTMLParagraphElement;
	const form         = document.getElementById('config-form') as HTMLFormElement;

	function renderTeamInputs(): void {
		const n = Math.max(3, Math.min(32, Number(countInput.value) || 3));
		countInput.value = String(n);

		const current: string[] = Array.from(grid.querySelectorAll<HTMLInputElement>('input[name="team"]')).map(i => i.value);

		grid.innerHTML = '';
		for (let i = 0; i < n; i++) {
			const wrap = document.createElement('div');
			wrap.className = 'flex items-center gap-2';
			wrap.innerHTML = `
				<div class="shrink-0 w-8 h-8 rounded-lg bg-blue-100 text-blue-700 grid place-items-center text-xs font-bold">
					${i + 1}
				</div>
				<input name="team" type="text" autocomplete="off" class="cc-input"
					placeholder="Time ${i + 1}" value="${current[i] ?? ''}" maxlength="32" />
			`;
			grid.appendChild(wrap);
		}
	}

	function getSelected(name: string): string {
		const el = document.querySelector<HTMLInputElement>(`input[name="${name}"]:checked`);
		return el?.value ?? '';
	}

	function updateHint(): void {
		hintEl.textContent = HINTS[getSelected('format') as Format];
	}

	btnPlus.addEventListener('click', () => {
		countInput.value = String(Number(countInput.value) + 1);
		renderTeamInputs();
	});
	btnMinus.addEventListener('click', () => {
		countInput.value = String(Number(countInput.value) - 1);
		renderTeamInputs();
	});
	countInput.addEventListener('input', renderTeamInputs);

	btnFill.addEventListener('click', () => {
		const sport = getSelected('sport') as Sport;
		const pool = EXAMPLE_TEAMS[sport];
		const inputs = Array.from(grid.querySelectorAll<HTMLInputElement>('input[name="team"]'));
		inputs.forEach((inp, idx) => { inp.value = pool[idx % pool.length]; });
	});

	document.querySelectorAll<HTMLInputElement>('input[name="format"]').forEach(el => {
		el.addEventListener('change', updateHint);
	});

	form.addEventListener('submit', (ev) => {
		ev.preventDefault();
		errEl.classList.add('hidden');

		const inputs = Array.from(grid.querySelectorAll<HTMLInputElement>('input[name="team"]'));
		const teams  = inputs.map(i => i.value.trim()).filter(Boolean);

		if (teams.length < 3) {
			errEl.textContent = 'Preencha ao menos 3 times para criar o campeonato.';
			errEl.classList.remove('hidden');
			return;
		}

		const dup = teams.find((t, i) => teams.indexOf(t) !== i);
		if (dup) {
			errEl.textContent = `Nome de time duplicado: "${dup}". Os nomes precisam ser únicos.`;
			errEl.classList.remove('hidden');
			return;
		}

		const config: Config = {
			teams,
			sport:  getSelected('sport')  as Sport,
			gender: getSelected('gender') as Gender,
			format: getSelected('format') as Format,
		};

		const t = generateTournament(config);
		saveTournament(t);
		// Volta para a listagem — o torneio recém-criado aparece no topo.
		window.location.href = '/';
	});

	renderTeamInputs();
	updateHint();
</script>
